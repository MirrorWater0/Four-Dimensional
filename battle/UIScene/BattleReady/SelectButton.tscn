[sub_resource type="Shader" id="Shader_benw5"]
code = "shader_type canvas_item;

// --- Settings ---
uniform vec4 glow_color : source_color = vec4(1.0, 0.2, 0.5, 1.0);
uniform float rect_size : hint_range(0.0, 1.0) = 0.2;
uniform float intensity : hint_range(0.001, 0.05) = 0.005;

// --- Directional Control (Multipliers) ---
// 1.0 is default. 0.0 is off.
uniform float glow_left : hint_range(0.0, 5.0) = 1.0;
uniform float glow_right : hint_range(0.0, 5.0) = 1.0;
uniform float glow_top : hint_range(0.0, 5.0) = 1.0;
uniform float glow_bottom : hint_range(0.0, 5.0) = 1.0;

// --- Boundary Fade ---
uniform float edge_softness : hint_range(0.0, 0.5) = 0.1;

float sdBox(vec2 p, vec2 b) {
    vec2 d = abs(p) - b;
    return length(max(d, 0.0)) + min(max(d.x, d.y), 0.0);
}

void fragment() {
	vec4 tex = texture(TEXTURE,UV /2.);
    // 1. Coordinates (-1 to 1)
    vec2 p = 2.0 * (UV - 0.5);

    // 2. Base SDF Distance
    float dist = sdBox(p, vec2(rect_size));

    // 3. DIRECTIONAL INTENSITY LOGIC
    // Determine if pixel is on Left (-1) or Right (+1) side
    float h_mix = smoothstep(-0.01, 0.01, p.x);
    // Mix between Left and Right intensity
    float h_int = mix(glow_left, glow_right, h_mix);

    // Determine if pixel is on Top (-1) or Bottom (+1) side (Godot UV.y is positive down)
    float v_mix = smoothstep(-0.01, 0.01, p.y);
    // Mix between Top and Bottom intensity
    float v_int = mix(glow_top, glow_bottom, v_mix);

    // Calculate which edge is closer: Horizontal or Vertical?
    // d_geom measures distance to the respective axis edge relative to box size
    vec2 d_geom = abs(p) - vec2(rect_size);
    // If d_geom.x > d_geom.y, we are closer to the Left/Right edges.
    float corner_blend = smoothstep(-0.01, 0.01, d_geom.x - d_geom.y);

    // Combine to get the final multiplier for this specific pixel
    float current_side_intensity = mix(v_int, h_int, corner_blend);

    // 4. Calculate Glow
    // Apply the directional multiplier to the base intensity
    float glow = (intensity * current_side_intensity) / abs(dist);
    glow = clamp(glow, 0.0, 1.0);

    // 5. Boundary Mask (Prevent cut-off)
    float dist_to_edge = 1.0 - max(abs(p.x), abs(p.y));
    float mask = smoothstep(0.0, edge_softness, dist_to_edge);

    // 6. Output
    COLOR = glow_color;
    COLOR.a *= tex.a;
}"

