[sub_resource type="Shader" id="Shader_q1qv0"]
code = "shader_type canvas_item;

// --- 颜色与样式 ---
uniform vec4 star_color : source_color = vec4(0.95, 0.90, 0.75, 1.0); // 香槟金
uniform float line_width = 0.025;    // 外星形的线条粗细
uniform float glow_strength = 20.0;  // 发光强度

// --- 星形尺寸 ---
uniform float outer_size = 0.35;     // 外层空心星形的大小
uniform float inner_size = 0.12;     // 内层实心星形的大小
uniform float concavity = 1.2;       // 星形的内凹/尖锐程度 (推荐 0.8 到 1.5)

// 【核心数学公式】：完美的内凹四角星 SDF
// 通过 length(p) + k * min(x,y) 构造出由四条抛物线组成的完美星形
float sdConcaveStar(vec2 p, float r, float k) {
    p = abs(p);
    float len = length(p);
    
    // 保护机制，防止中心点出现 NaN
    if (len < 0.00001) return -r; 
    
    float m = min(p.x, p.y);
    float d = len + k * m - r;
    
    // 计算梯度对距离进行完美归一化，保证不管怎么变形，线条粗细绝对均匀
    float grad_len = sqrt(1.0 + k*k + 2.0*k*m / len);
    return d / grad_len;
}

void fragment() {
    // 获取绝对精准的 1 像素宽度，用于抗锯齿
    float px = fwidth(UV.y);
    if (px == 0.0) px = 0.005; 
    
    // 坐标居中 (-0.5 到 0.5)
    vec2 uv = UV - 0.5;
    
    // --- 绘制外层空心星形 ---
    float d_outer = sdConcaveStar(uv, outer_size, concavity);
    // 使用 abs() 将实心变成空心线条
    float d_hollow = abs(d_outer) - line_width * 0.5;
    
    // --- 绘制内层实心星形 ---
    // 内层的星星可以稍微没那么尖锐，所以 concavity - 0.2
    float d_inner = sdConcaveStar(uv, inner_size, max(0.0, concavity - 0.2));
    
    // --- 图形合并 ---
    float final_dist = min(d_hollow, d_inner);
    
    // --- 极致平滑抗锯齿 ---
    // 强制使用 1.5 像素宽度的柔和过渡带
    float shape_alpha = smoothstep(px * 1.5, -px * 1.5, final_dist);
    
    // --- 发光效果 ---
    float glow = exp(-max(final_dist, 0.0) * glow_strength);
    
    // --- 颜色混合输出 ---
    vec4 final_color = vec4(0.0);
    
    // 底层：泛光层
    final_color.rgb = star_color.rgb;
    final_color.a = glow * 0.5; 
    
    // 表层：实体高亮层
    final_color.rgb = mix(final_color.rgb, star_color.rgb * 1.5, shape_alpha);
    final_color.a = max(final_color.a, shape_alpha);
    
    COLOR = final_color;
}
"

