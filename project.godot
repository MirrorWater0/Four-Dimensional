; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Four-Dimensional"
run/main_scene="res://PreloadeScene.tscn"
config/features=PackedStringArray("4.6", "C#", "Mobile")

[autoload]

MouseTrail="*uid://d0hwex3fc1sp4"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="tower"

[editor]

naming/scene_name_casing=1

[file_customization]

folder_colors={
"res://Equipment/": "orange",
"res://Event/": "blue",
"res://Menu/": "purple",
"res://Relic/": "gray",
"res://Shop/": "teal",
"res://asset/": "pink",
"res://battle/": "purple",
"res://battle/buff/": "green",
"res://battle/buff/StateIcon/": "green",
"res://character/": "green",
"res://character/EnemyCharacter/": "red",
"res://character/PlayerCharacter/": "blue",
"res://character/SkillBase/": "yellow",
"res://shader/": "red"
}

[global]

HDR=true

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d/compress_to": 0,
"mipmaps/generate": true,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}
spine.skel={}

[input]

Wheelup={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":8,"position":Vector2(128, 23),"global_position":Vector2(137, 69),"factor":1.0,"button_index":4,"canceled":false,"pressed":true,"double_click":false,"script":null)
]
}
Wheeldown={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":16,"position":Vector2(229, 6),"global_position":Vector2(238, 52),"factor":1.0,"button_index":5,"canceled":false,"pressed":true,"double_click":false,"script":null)
]
}

[rendering]

textures/canvas_textures/default_texture_filter=2
textures/default_filters/anisotropic_filtering_level=3
anti_aliasing/quality/msaa_2d=3
scaling_3d/mode=1
textures/decals/filter=5
