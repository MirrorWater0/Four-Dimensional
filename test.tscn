[sub_resource type="Shader" id="Shader_8uh7m"]
code = "shader_type canvas_item;

// 关键：hint_screen_texture 让 Shader 去读取 BackBuffer 里的内容
uniform sampler2D screen_tex : hint_screen_texture, filter_linear_mipmap;

uniform vec4 glow_color : source_color = vec4(0.0, 0.6, 1.0, 1.0);
uniform float thickness : hint_range(0.0, 30.0) = 5.0;
uniform float intensity : hint_range(0.0, 10.0) = 2.0;

void fragment() {
    // 1. 采样屏幕背景（即火苗的形状）
    // 注意：在 ColorRect 里我们要用 SCREEN_UV
    vec4 tex = texture(screen_tex, SCREEN_UV);
    
    // 2. 采样周围像素
    vec2 size = SCREEN_PIXEL_SIZE * thickness;
    float a = tex.a;
    a = max(a, texture(screen_tex, SCREEN_UV + vec2(size.x, 0.0)).a);
    a = max(a, texture(screen_tex, SCREEN_UV + vec2(-size.x, 0.0)).a);
    a = max(a, texture(screen_tex, SCREEN_UV + vec2(0.0, size.y)).a);
    a = max(a, texture(screen_tex, SCREEN_UV + vec2(0.0, -size.y)).a);

    // 3. 物理剔除，解决方块问题
    if (a < 0.001) {
        discard;
    }

    // 4. 合成发光
    vec3 final_rgb = mix(glow_color.rgb * intensity, tex.rgb, tex.a);
    float final_a = max(tex.a, a * glow_color.a);

    COLOR = vec4(final_rgb, final_a);
}
"

